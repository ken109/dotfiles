# Theme
theme = Vercel

# Font
font-family = Hack Nerd Font Mono
font-size = 12

# Window
window-padding-x = 10
window-padding-y = 10
window-decoration = false
background-opacity = 0.75
background-blur = true
maximize = true

# macOS
macos-option-as-alt = true

# Keybinds
keybind = alt+left=unbind
keybind = alt+right=unbind
